{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "node16",
    "target": "es2021",
    "moduleResolution": "node16",
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"]
}

{
  "name": "d-fi-core",
  "version": "1.3.5",
  "description": "Core module for d-fi",
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "bun run lint && tsc",
    "prebuild": "bun run lint",
    "build": "tsc",
    "test": "bun test ./__tests__/api.ts ./__tests__/converter/*.ts"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "repository": "https://github.com/d-fi/d-fi-core",
  "author": "Sayem Chowdhury",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.16.1",
    "browser-id3-writer": "^4.4.0",
    "p-queue": "^6.6.2",
    "spotify-uri": "^4.1.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "3.8.3",
    "typescript": "6.0.3"
  }
}
